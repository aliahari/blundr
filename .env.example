# Chess Blunder Analyzer Configuration
# Copy this file to .env and modify as needed
#
# This file is read by two different consumers:
#   1. Local dev (`uv run python run.py`) — pydantic-settings loads it
#      directly, every var below applies.
#   2. `docker compose` — reads the same root .env for ${VAR} substitution
#      in docker-compose.yml. Two vars are deliberately NOT passed through
#      from here: DEBUG is hardcoded to "False" in docker-compose.yml
#      (reload mode has no place in a deployed container), and DATABASE_URL
#      is hardcoded to the path matching the persistent volume mount — do
#      not try to override either from this file for the Docker deployment.

# Application settings
APP_NAME=Chess Blunder Analyzer
APP_VERSION=0.1.0
DEBUG=True

# CORS settings (comma-separated list of origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Lichess API settings
LICHESS_API_BASE_URL=https://lichess.org/api
LICHESS_API_TIMEOUT=30.0
LICHESS_RATE_LIMIT_DELAY=1.0

# Default game fetching settings
DEFAULT_MAX_GAMES=100
DEFAULT_GAME_TYPES=rapid,blitz,classical

# Database
DATABASE_URL=sqlite+aiosqlite:///./blundr.db

# Auth — set a real secret in any non-local deployment
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_MINUTES=10080

# Password reset links point back at this URL (?reset_token=... is appended)
FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30

# SMTP for password-reset emails. Leave SMTP_HOST empty for local dev — the
# reset link is logged to the console instead of emailed, so the whole flow
# is testable without real credentials. Works with any provider's SMTP
# endpoint (a Gmail app password, Mailgun/Postmark/SES SMTP, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Blundr <noreply@yourdomain.com>
SMTP_USE_TLS=True

# Engine analysis
STOCKFISH_PATH=stockfish
ANALYSIS_DEPTH=12
ANALYSIS_MAX_TIME_PER_POSITION=0.5
ANALYSIS_CONCURRENCY=4
BLUNDER_WINPROB_THRESHOLD=25.0

# --- docker-compose only, below this line ---

# Public domain for the Caddy reverse proxy. Set this once DNS points at
# your VPS and Caddy will provision a Let's Encrypt cert automatically.
# Leave unset (or ":80") to test against the VPS's bare IP first — plain
# HTTP, no TLS.
DOMAIN=

# Pinned Stockfish build (see Dockerfile header for how to bump these).
# Uncomment to override the defaults baked into the Dockerfile.
# STOCKFISH_VERSION=sf_18
# STOCKFISH_VARIANT=avx2
# STOCKFISH_SHA256=536c0c2c0cf06450df0bfb5e876ef0d3119950703a8f143627f990c7b5417964

# Subdomain for the self-hosted GoatCounter analytics dashboard (privacy-
# friendly, cookie-free pageview tracking — no consent banner needed). Needs
# its own DNS A record pointed at this VPS, same as DOMAIN. Leave unset to
# skip: Caddy falls back to a local-only "stats.localhost" address that
# nothing external can reach, so GoatCounter still runs but isn't exposed.
# STATS_DOMAIN=stats.yourdomain.com
